# Скопируйте в .env и заполните нужными значениями.

# Рабочий каталог агента (подставляется в mcp.config.json).
AGENT_WORKDIR=./_state

# --- LLM ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- MCP (internal http server, опционально) ---
INTERNAL_MCP_TOKEN=

# --- A2A ---
A2A_PUBLIC_URL=http://localhost:7701
A2A_AUTH_SCHEME=none           # none | bearer | mtls | oidc
A2A_BEARER_TOKEN=
